msgid "袙 屑褉邪褔薪芯屑 谢械褋褍"
msgstr ""

#. ~ Scenario name
#: scenarios/skull_knight_encounter.json
msgid "(袘袝袪小袝袪袣)袙褋褌褉械褔邪 褋 袪褘褑邪褉械屑 小泻械谢械褌邪"
msgstr ""

#. ~ Scenario description
#: scenarios/skull_knight_encounter.json
msgid "袙褘 芯泻邪蟹褘胁邪械褌械褋褜 薪邪 锌褍褋褌芯褕懈, 芯泻褉褍卸褢薪薪芯泄 屑褉邪泻芯屑 懈 芯斜谢芯屑泻邪屑懈 写褉械胁薪械谐芯 蟹邪屑泻邪. 袙写邪谢械泻械 褋谢褘褕懈褌褋褟 褌褟卸褢谢芯械 写褘褏邪薪懈械 懈 蟹胁芯薪 屑械褌邪谢谢邪 鈥?锌械褉械写 胁邪屑懈 锌褉械写褋褌邪褢褌 袪褘褑邪褉褜 小泻械谢械褌邪, 胁芯懈薪 胁 写芯褋锌械褏邪褏, 懈蟹谢褍褔邪褞褖懈泄 褌褢屑薪褍褞 褋懈谢褍. 袝谐芯 屑邪谐懈褔械褋泻懈械 邪褌邪泻懈 懈 泻芯薪薪褘泄 薪邪褋泻芯泻 褍谐褉芯卸邪褞褌 胁邪褕械泄 卸懈蟹薪懈. 袚芯褌芯胁褜褌械褋褜 泻 褝锌懈褔械褋泻芯泄 斜懈褌胁械 褋 褝褌懈屑 谢械谐械薪写邪褉薪褘屑 褋褍褖械褋褌胁芯屑, 锌芯谢邪谐邪褟褋褜 薪邪 褋胁芯褞 褋懈谢褍 懈 褋屑械泻邪谢泻褍 胁 褝褌芯屑 褉邪蟹褉褍褕械薪薪芯屑 屑懈褉械."
msgstr ""

#. ~ Scenario start location name
#: scenarios/skull_knight_encounter.json
msgid "袪邪蟹褉褍褕械薪薪邪褟 锌褍褋褌芯褕褜"
msgstr ""

#. ~ Scenario name
#: scenarios/void_apostle_confrontation.json
msgid "(袘袝袪小袝袪袣)袩褉芯褌懈胁芯褋褌芯褟薪懈械 袗锌芯褋褌芯谢褍 袙芯泄写褍"
msgstr ""

#. ~ Scenario description
#: scenarios/void_apostle_confrontation.json
msgid "袙褘 褋褌芯懈褌械 胁 褌褢屑薪芯屑, 懈褋泻邪卸褢薪薪芯屑 懈蟹屑械褉械薪懈懈, 谐写械 胁芯蟹写褍褏 写褉芯卸懈褌 芯褌 锌褋懈褏懈褔械褋泻芯泄 褝薪械褉谐懈懈. 袩械褉械写 胁邪屑懈 锌芯褟胁谢褟械褌褋褟 袗锌芯褋褌芯谢 袙芯泄写 鈥?褋褍褖械褋褌胁芯 褋 芯褌泻褉褘褌褘屑 屑芯蟹谐芯屑, 褔褜褟 褋懈谢邪 屑邪薪懈锌褍谢懈褉褍械褌 褉械邪谢褜薪芯褋褌褜褞. 袝谐芯 胁蟹谐谢褟写 锌褉芯薪懈泻邪械褌 胁 写褍褕褍, 邪 邪褍褉邪 锌芯写邪胁谢褟械褌 胁芯谢褞. 袚芯褌芯胁褜褌械褋褜 泻 斜懈褌胁械 褋 褝褌懈屑 写械屑芯薪懈褔械褋泻懈屑 谢懈写械褉芯屑, 锌芯谢邪谐邪褟褋褜 薪邪 褋褌芯泄泻芯褋褌褜 懈 褏懈褌褉芯褋褌褜 胁 褝褌芯屑 泻芯褕屑邪褉薪芯屑 屑懈褉械."
msgstr ""

#. ~ Scenario start location name
#: scenarios/void_apostle_confrontation.json
msgid "袠褋泻邪卸褢薪薪芯械 懈蟹屑械褉械薪懈械"
msgstr ""
