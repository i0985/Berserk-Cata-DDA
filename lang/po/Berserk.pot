msgstr ""

#. ~ Item description
#: monsterdrops/beast_drops.json
msgid "袨褌胁褉邪褌懈褌械谢褜薪褘泄 泻褍褋芯泻 褌褢屑薪芯泄 锌谢芯褌懈, 褋谢邪斜芯 锌褍谢褜褋懈褉褍褞褖懈泄. 袩芯褏芯卸械, 芯锌邪褋薪芯 写谢褟 褍锌芯褌褉械斜谢械薪懈褟."
msgstr ""

#. ~ Scenario name
#: scenarios/berserk_pursuer.json
msgid "(袘袝袪小袝袪袣)袘械褋褋屑械褉褌薪褘泄 袟芯写写"
msgstr ""

#. ~ Scenario description
#: scenarios/berserk_pursuer.json
msgid "袙褘 芯泻邪蟹褘胁邪械褌械褋褜 胁 屑褉邪褔薪芯屑 谢械褋褍, 谐写械 褌褟卸褢谢褘械 褕邪谐懈 懈 褉褢胁 袧芯褋褎械褉邪褌褍 袟芯写写邪 褍卸械 褝褏芯屑 褉邪蟹薪芯褋褟褌褋褟 胁 胁芯蟹写褍褏械. 协褌芯褌 谢械谐械薪写邪褉薪褘泄 邪锌芯褋褌芯谢, 卸邪卸写褍褖懈泄 斜懈褌胁褘, 薪邪褔邪谢 蟹邪 胁邪屑懈 芯褏芯褌褍 褋 褋邪屑芯谐芯 薪邪褔邪谢邪. 协褌芯 薪械 锌褉芯褋褌芯 胁褘卸懈胁邪薪懈械 鈥?褝褌芯 写褍褝谢褜 薪邪 胁褘卸懈胁邪薪懈械, 谐写械 泻邪卸写邪褟 褋械泻褍薪写邪 屑芯卸械褌 褋褌邪褌褜 锌芯褋谢械写薪械泄. 小屑芯卸械褌械 谢懈 胁褘 褋褌褉邪褌械谐懈褔械褋泻懈 褍泄褌懈 芯褌 械谐芯 褉邪蟹褉褍褕懈褌械谢褜薪褘褏 褍写邪褉芯胁, 蟹邪屑邪薪懈褌褜 胁 谢芯胁褍褕泻褍 懈谢懈 胁褋褌褉械褌懈褌褜 谢懈褑芯屑 泻 谢懈褑褍, 锌芯谢邪谐邪褟褋褜 谢懈褕褜 薪邪 褋胁芯褞 褋懈谢褍 懈 褏懈褌褉芯褋褌褜? 袚芯褌芯胁褜褌械褋褜 泻 褝锌懈褔械褋泻芯泄 褋褏胁邪褌泻械 褋 写械屑芯薪芯屑, 褔褜褟 屑芯褖褜 锌褉械胁芯褋褏芯写懈褌 胁褋褢, 褔褌芯 胁褘 胁懈写械谢懈 胁 褝褌芯屑 褉邪蟹褉褍褕械薪薪芯屑 屑懈褉械."
msgstr ""

