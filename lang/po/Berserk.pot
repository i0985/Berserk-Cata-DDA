#. ~ Description of MOD "Berserk"
#: modinfo.json
msgid "袛芯斜邪胁谢褟械褌 泻芯薪褌械薪褌 懈蟹 谢械谐械薪邪写褉薪芯谐芯 邪薪懈屑械褉 袘械褉褋械褉泻. 袨褌泻褉芯泄 写谢褟 褋械斜褟 褌褢屑薪褘褏 褋褍褖械褋褌胁 写谢邪薪懈, 褋褉邪蟹懈褋褜 褋 谢械谐械薪写邪褉薪褘屑懈 写械屑芯薪邪屑懈, 懈谢懈 胁褘泻褍泄 懈 芯锌褉芯斜褍泄 谢械谐械薪邪写褉薪褘泄 屑械褔 袚邪褌褋邪."
msgstr ""

#. ~ Profession name
#: professions/professions.json
msgid "袘械褉褋械褉泻"
msgstr ""

#. ~ Profession description
#: professions/professions.json
msgid "孝褘 鈥?谐褉芯屑懈谢邪, 胁褘泻芯胁邪薪薪邪褟 胁 屑褟褋芯褉褍斜泻械 屑懈褉邪, 谐写械 蟹芯屑斜懈 鈥?谢懈褕褜 锌芯胁芯写 褉邪蟹屑褟褌褜 泻褍谢邪泻懈 懈 芯谐褉芯屑薪褘泄 屑械褔. 袧械谐褉邪屑芯褌薪褘泄, 蟹邪褌芯 褋 褉褍泻邪屑懈, 褔褌芯 褉褍斜褟褌 屑械褉褌胁械褑芯胁 泻邪泻 写褉芯胁邪, 褌褘 薪邪褑械锌懈谢 锌褉芯泻谢褟褌褍褞 斜褉芯薪褞, 泻芯褌芯褉邪褟 锌褜褢褌 褌胁芯褞 泻褉芯胁褜 斜褘褋褌褉械械, 褔械屑 褌褘 褍褋锌械胁邪械褕褜 锌褉芯谢懈胁邪褌褜 褔褍卸褍褞. 袣邪泻 褌褘 褋褞写邪 锌芯锌邪谢? 袧械褟褋薪芯, 薪芯 胁 褝褌芯屑 邪写褍 褋懈谢邪 鈥?褌胁芯泄 锌褉芯锌褍褋泻 胁 褋谢械写褍褞褖懈泄 写械薪褜."
msgstr ""

#. ~ Profession name
#: professions/professions.json
msgid "肖邪薪邪褌 袘械褉褋械褉泻邪"
msgstr ""

#. ~ Profession description
#: professions/professions.json
msgid "孝褘 锌械褉械褔懈褌邪谢 胁褋械 褌芯屑邪 '袘械褉褋械褉泻邪', 锌芯泻邪 蟹芯屑斜懈 谢芯屑懈谢懈褋褜 胁 写胁械褉褜 褌胁芯械泄 泻胁邪褉褌懈褉褘, 懈 褉械褕懈谢: '袝褋谢懈 袚邪褌褋 褋屑芯谐, 褌芯 懈 褟 褋屑芯谐褍!' 小懈谢邪? 袧褍, 薪械 褋芯胁褋械屑, 蟹邪褌芯 褍 褌械斜褟 械褋褌褜 褋邪屑芯写械谢褜薪邪褟 泻芯锌懈褟 械谐芯 屑械褔邪 懈 褋褌懈谢褜薪褘泄 褏褍写懈 褋 斜邪薪写邪薪芯泄 鈥?懈写械邪谢褜薪芯, 褔褌芯斜褘 锌褉懈褌胁芯褉懈褌褜褋褟 泻褉褍褌褘屑. 袙 褝褌芯屑 邪锌芯泻邪谢懈锌褋懈褋械 褌褘 褎邪薪邪褌 褋 袦袝效孝袨袡, 邪 薪械 褋 褕邪薪褋邪屑懈, 泻芯谐写邪 薪懈斜褍写褜 懈 褌褘 褋褌邪薪械褕褜 褋胁芯斜芯写薪褘屑."
msgstr ""

#. ~ Item name
#: items/forged_guts_sword.json
msgid "袙褘泻芯胁邪薪薪褘泄 屑械褔 袚邪褌褋邪"
msgid_plural "袙褘泻芯胁邪薪薪褘械 屑械褔懈 袚邪褌褋邪"
msgstr[0] ""
msgstr[1] ""

#. ~ Item description
#: items/forged_guts_sword.json
msgid "协褌芯褌 屑邪褋褋懈胁薪褘泄 泻谢懈薪芯泻 鈥?褌胁芯褟 褋褌邪褉邪褌械谢褜薪邪褟 锌芯锌褘褌泻邪 胁芯褋褋芯蟹写邪褌褜 谢械谐械薪写邪褉薪褘泄 屑械褔 袚邪褌褋邪, 芯 泻芯褌芯褉芯屑 褏芯写褟褌 褋谢褍褏懈 褋褉械写懈 胁褘卸懈胁褕懈褏. 袙褘泻芯胁邪薪薪褘泄 懈蟹 蟹邪泻邪谢褢薪薪芯泄 褋褌邪谢懈, 芯薪 锌芯褔褌懈 泻邪泻 褌芯褌, 褔褌芯 褉邪蟹褉褍斜邪谢 写褉邪泻芯薪芯胁 懈 邪锌芯褋褌芯谢芯胁 胁 懈褋褌芯褉懈褟褏... 械褋谢懈 斜褘 芯薪懈 斜褘谢懈 锌褉邪胁写芯泄. 孝褟卸褢谢褘泄, 谐褉褍斜褘泄 懈 芯褋褌褉褘泄, 芯薪 斜褜褢褌 写邪谢械泻芯 懈 褋懈谢褜薪芯 鈥?懈写械邪谢褜薪芯 写谢褟 蟹芯屑斜懈 懈谢懈 褔械谐芯 锌芯褏褍卸械."
msgstr ""

#. ~ Item name
#: items/true_guts_sword.json
msgid "袠褋褌懈薪薪褘泄 屑械褔 袚邪褌褋邪"
msgid_plural "袠褋褌懈薪薪褘械 屑械褔懈 袚邪褌褋邪"
msgstr[0] ""
msgstr[1] ""

#. ~ Item description
#: items/true_guts_sword.json
msgid "袛谢褟 袚邪褌褋邪 褝褌芯褌 屑芯褖薪褘泄, 屑邪褋褋懈胁薪褘泄 屑械褔 芯褖褍褖邪械褌褋褟 泻邪泻 谢械谐泻懈泄 褍褌褟卸械谢械薪薪褘泄 泻谢懈薪芯泻 胁械褋芯屑 芯泻芯谢芯 5 泻谐. 袨薪 褋芯蟹写邪薪 写谢褟 褉邪蟹褉褍斜邪薪懈褟 胁褉邪谐芯胁 薪邪 褔邪褋褌懈, 胁芯锌谢芯褖邪褟 胁 褋械斜械 褋懈谢褍 懈 褉械褕懈屑芯褋褌褜, 褋褉邪胁薪懈屑褍褞 褋 谢械谐械薪写邪褉薪褘屑懈 屑械褔邪屑懈."
msgstr ""

#. ~ Item name
#: items/nosferatu_zodd_sword.json
msgid "袦械褔 袧芯褋褎械褉邪褌褍 袟芯写写邪"
msgid_plural "袦械褔懈 袧芯褋褎械褉邪褌褍 袟芯写写邪"
msgstr[0] ""
msgstr[1] ""

#. ~ Item description
#: items/nosferatu_zodd_sword.json
msgid "袣芯谢芯褋褋邪谢褜薪褘泄 屑械褔, 泻芯褌芯褉褘屑 胁谢邪写械械褌 谐褉芯蟹薪褘泄 袧芯褋褎械褉邪褌褍 袟芯写写. 袣芯胁邪薪 胁 卸械褋褌芯泻芯屑 褋褌懈谢械, 薪邪锌芯屑懈薪邪褞褖械屑 泻褍褕邪薪褋泻芯械 褉械屑械褋谢芯, 褝褌芯褌 屑械褔 褋 谢械谐泻芯褋褌褜褞 褉邪蟹褉械蟹邪械褌 锌谢芯褌褜 懈 泻芯褋褌懈. 孝芯谢褜泻芯 褋邪屑褘械 屑芯谐褍褖械褋褌胁械薪薪褘械 屑芯谐褍褌 胁谢邪写械褌褜 懈屑 褝褎褎械泻褌懈胁薪芯."
msgstr ""

#. ~ Item name
#: items/void_crystal.json
