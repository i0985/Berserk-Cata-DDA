msgstr ""

#. ~ Item name
#: monsterdrops/griffith_drops.json
msgid "袨褋泻芯谢芯泻 袗锌芯褋褌芯谢邪"
msgstr ""

#. ~ Item description
#: monsterdrops/griffith_drops.json
msgid "袟褍斜褔邪褌褘泄 褎褉邪谐屑械薪褌, 锌褍谢褜褋懈褉褍褞褖懈泄 褌褢屑薪芯泄 褝薪械褉谐懈械泄, 芯褌芯褉胁邪薪薪褘泄 芯褌 锌芯褌褍褋褌芯褉芯薪薪械谐芯 褋褍褖械褋褌胁邪."
msgstr ""

#. ~ Item name
